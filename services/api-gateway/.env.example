# API Gateway Environment Variables
NODE_ENV=local
PORT=3000
JWT_SECRET=your-local-dev-secret-min-32-chars

# Service URLs (used in local/dev only; in EKS these come from Kubernetes DNS)
USER_SERVICE_URL=http://localhost:3001
ORDER_SERVICE_URL=http://localhost:3002
PRODUCT_SERVICE_URL=http://localhost:8000
ANALYTICS_SERVICE_URL=http://localhost:8001
NOTIFICATION_SERVICE_URL=http://localhost:8002

# AWS (only needed when NODE_ENV != local)
AWS_REGION=us-east-2
PROJECT_NAME=ecom-microservices
ENVIRONMENT=prod

CORS_ORIGIN=http://localhost:3000
